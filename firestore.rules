rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // L'admin principale ha sempre accesso
    function isAdminEmail() {
      return request.auth.token.email == 'siriomediahouse@gmail.com';
    }

    // Utente presente in allowed_users e attivo
    function isAllowed() {
      return isAdminEmail() || (
        request.auth.token.email != null &&
        exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/allowed_users/$(request.auth.token.email)).data.active == true
      );
    }

    // Dati app master admin — flat collections (dati storici)
    match /clients/{doc}           { allow read, write: if request.auth != null && isAllowed(); }
    match /appointments/{doc}      { allow read, write: if request.auth != null && isAllowed(); }
    match /services/{doc}          { allow read, write: if request.auth != null && isAllowed(); }
    match /staff/{doc}             { allow read, write: if request.auth != null && isAllowed(); }
    match /settings/{doc}          { allow read, write: if request.auth != null && isAllowed(); }
    match /message_logs/{doc}      { allow read, write: if request.auth != null && isAllowed(); }
    match /client_treatments/{doc} { allow read, write: if request.auth != null && isAllowed(); }
    match /inventory/{doc}         { allow read, write: if request.auth != null && isAllowed(); }

    // Dati workspace isolati — ogni utente accede solo al proprio workspace
    match /workspaces/{workspaceId}/{collection}/{doc} {
      allow read, write: if request.auth != null && (
        isAdminEmail() ||
        (
          isAllowed() &&
          get(/databases/$(database)/documents/allowed_users/$(request.auth.token.email)).data.workspace_id == workspaceId
        )
      );
    }

    // Gestione accessi — solo l'admin principale può scrivere
    match /allowed_users/{email} {
      allow read:  if request.auth != null && (isAdminEmail() || request.auth.token.email == email);
      allow write: if request.auth != null && isAdminEmail();
    }

    // Richieste di accesso — utente autenticato crea/legge la propria; admin legge/scrive tutte
    match /access_requests/{uid} {
      allow read:   if request.auth != null && (isAdminEmail() || request.auth.uid == uid);
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && isAdminEmail();
    }
  }
}
